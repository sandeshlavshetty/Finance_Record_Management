# LOCAL DEVELOPMENT ONLY
DEBUG=1
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=finance_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# JWT Tokens
ACCESS_TOKEN_LIFETIME_MINUTES=30
REFRESH_TOKEN_LIFETIME_DAYS=7

# Admin Setup (change for production!)
SETUP_TOKEN=test-setup-token-change-in-production

# PRODUCTION NOTES:
# - Set DEBUG=0 on Render
# - Generate new SECRET_KEY with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# - Use Render's PostgreSQL connection string for POSTGRES_* variables
# - Use unique SETUP_TOKEN for production
# - Add your Render domain to ALLOWED_HOSTS


